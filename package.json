{
  "name": "webpilot-monorepo",
  "private": true,
  "version": "0.0.12",
  "description": "WebPilot — AI 网页助手（侧边面板）monorepo root",
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @webpilot/extension dev",
    "build": "pnpm --filter @webpilot/extension build",
    "preview": "pnpm --filter @webpilot/extension preview",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:watch": "pnpm --filter @webpilot/extension test:watch"
  },
  "packageManager": "pnpm@9.0.0"
}
